# TapCanvas API (NestJS + Node.js) env

# HTTP port (default: 8788)
PORT=8788

# Preferred: Postgres (Prisma)
# Example: postgres://postgres:postgres@127.0.0.1:5432/tapcanvas
DATABASE_URL=
# Docker compose (container-internal DSN; host should be `postgres`)
# DATABASE_URL_DOCKER=postgresql://tapcanvas:tapcanvas@postgres:5432/tapcanvas?schema=public
# Compose built-in postgres defaults
# POSTGRES_DB=tapcanvas
# POSTGRES_USER=tapcanvas
# POSTGRES_PASSWORD=tapcanvas
# POSTGRES_PORT=5432
# Optional backup dir override (inside api container)
# PG_BACKUP_DIR=/app/backups
# Optional backup retention count (default: 1, keep newest predeploy dumps only)
# PG_BACKUP_KEEP_LATEST=1

# Optional: SQLite source path (only for sqlite->postgres migration script)
# TAPCANVAS_DB_PATH=.data/tapcanvas.sqlite

# JWT secret (default: dev-secret)
JWT_SECRET=dev-secret

# Optional: auth login channels
# EMAIL_LOGIN_DEBUG=1
# PHONE_LOGIN_DEBUG=1
# Debug trace for phone OTP request/verify chain (1 to enable)
# AUTH_PHONE_OTP_TRACE=1
# Optional: Redis for phone OTP / workers
# - Local host run: redis://127.0.0.1:6379
# - Docker Compose network: redis://redis:6379
# REDIS_URL=redis://127.0.0.1:6379

# Optional: Aliyun SMS (used by /auth/phone/request)
# Required for non-debug phone login:
# ALIYUN_SMS_ACCESS_KEY_ID=
# ALIYUN_SMS_ACCESS_KEY_SECRET=
# ALIYUN_SMS_SIGN_NAME=
# ALIYUN_SMS_TEMPLATE_CODE=
# Optional override (default: dysmsapi.aliyuncs.com)
# ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com

# Optional: internal ops token (enables /internal/* endpoints)
INTERNAL_WORKER_TOKEN=change-me

# Optional: object storage for asset hosting/upload (Cloudflare R2 or RustFS-compatible S3)
# Cloudflare R2
# Simplest form: provide the bucket URL directly. The server will parse:
# - endpoint: https://4081ef0b6d72113281b2311ebedc3edb.r2.cloudflarestorage.com
# - bucket: canvas-pro
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_URL=https://4081ef0b6d72113281b2311ebedc3edb.r2.cloudflarestorage.com/canvas-pro
# Optional split config if you prefer not to use R2_BUCKET_URL:
# R2_ENDPOINT_URL=https://4081ef0b6d72113281b2311ebedc3edb.r2.cloudflarestorage.com
# R2_BUCKET=canvas-pro
# Optional public asset base (custom domain / r2.dev). If omitted, hono-api will serve
# uploaded assets through its own `/assets/r2/*` proxy route.
# R2_PUBLIC_BASE_URL=https://assets.example.com
# Optional region override (default: auto)
# R2_REGION=auto
#
# Legacy RustFS-compatible S3 config remains supported:
# RUSTFS_ACCESS_KEY_ID=
# RUSTFS_SECRET_ACCESS_KEY=
# RUSTFS_ENDPOINT_URL=
# RUSTFS_BUCKET=
# RUSTFS_PUBLIC_BASE_URL=
# RUSTFS_REGION=cn-east-1

# Optional: prompt-evolution worker defaults
# - Cron at local midnight by default
# - Worker uses /internal/prompt-evolution/run with INTERNAL_WORKER_TOKEN
# PROMPT_EVOLUTION_CRON=0 0 * * *
# PROMPT_EVOLUTION_TZ=America/Los_Angeles
# PROMPT_EVOLUTION_SINCE_HOURS=24
# PROMPT_EVOLUTION_MIN_SAMPLES=30
# PROMPT_EVOLUTION_DRY_RUN=0
# PROMPT_EVOLUTION_CONCURRENCY=1

# Optional: agents HTTP bridge (used by /public/agents/chat)
# Docker Compose: keep default `http://agents-bridge:8799` from compose service env
# Local host run (non-docker): `http://127.0.0.1:8799`
# AGENTS_BRIDGE_BASE_URL=http://127.0.0.1:8799
# AGENTS_BRIDGE_TOKEN=
# Optional: agents bridge request timeout (ms, default: 600000; clamp: 5000~1800000)
# AGENTS_BRIDGE_TIMEOUT_MS=600000

# WeChat Pay V3 (direct-connect, H5/PC)
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_APP_ID=
# WECHAT_PAY_MCH_SERIAL_NO=
# WECHAT_PAY_PRIVATE_KEY=\"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\"
# WECHAT_PAY_PLATFORM_PUBLIC_KEY=\"-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----\"
# WECHAT_PAY_API_V3_KEY=
# WECHAT_PAY_NOTIFY_URL=https://your-domain.com/wechat-pay/callback
# Optional (Node local dev): load cert/key from files instead of pasting PEM.
# Auto-discovery defaults:
# - cert/apiclient_key.pem or apps/hono-api/cert/apiclient_key.pem
# - cert/apiclient_cert.pem or apps/hono-api/cert/apiclient_cert.pem (auto parse serial no)
# - cert/wechatpay_platform_public_key.pem (platform public key)
# WECHAT_PAY_PRIVATE_KEY_FILE=cert/apiclient_key.pem
# WECHAT_PAY_MCH_CERT_FILE=cert/apiclient_cert.pem
# WECHAT_PAY_PLATFORM_PUBLIC_KEY_FILE=cert/wechatpay_platform_public_key.pem
# Optional inline merchant cert PEM (if not using file)
# WECHAT_PAY_MCH_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# Legacy aliases accepted (for Tigshop-style env naming):
# WXPAY_MCHID=<same as WECHAT_PAY_MCH_ID>
# WECHAT_APP_ID=<same as WECHAT_PAY_APP_ID>
# WECHAT_NOTIFY_URL=<same as WECHAT_PAY_NOTIFY_URL>
# Note: WECHAT_APP_SECRET is not used by this H5 pay v3 signing/callback flow.

# Optional: Yunwu generateContent acceleration guards for /public/chat image tasks
# Per-attempt timeout (ms). default: 600000; clamp: 5000~600000
# YUNWU_GENERATE_CONTENT_TIMEOUT_MS=600000
# Maximum fallback attempts. defaults: 3 (text_to_image), 6 (image_edit with refs); clamp: 1~20
# YUNWU_GENERATE_CONTENT_MAX_ATTEMPTS=4
# Maximum retryable-error attempts (timeouts/5xx/429) before early fail. default: 2; clamp: 1~10
# YUNWU_GENERATE_CONTENT_RETRYABLE_BUDGET=2

# Optional: autostart local agents bridge (dev only)
# When enabled and AGENTS_BRIDGE_BASE_URL is empty, the API will spawn `pnpm --filter agents dev -- serve ...`
# and set AGENTS_BRIDGE_BASE_URL automatically. The bridge now starts with `AGENTS_PROFILE=code`.
# AGENTS_BRIDGE_AUTOSTART=1
# AGENTS_BRIDGE_HOST=127.0.0.1
# AGENTS_BRIDGE_PORT=8799
#
# Optional: agents skills dir (defaults to ./skills under the agents process cwd)
# Tip: when started via `pnpm --filter agents ...`, the agents process cwd is `apps/agents-cli`,
# so the default value `skills` already points to this repo's built-in skills (including `tapcanvas*`).
# If you start agents from repo root manually, you can set: AGENTS_SKILLS_DIR=apps/agents-cli/skills

# OpenClaw (Right Codes) subscription provisioning
# Only token is required. Base URL is optional for non-production debugging.
OPENCLAW_API_TOKEN=
# OPENCLAW_API_BASE_URL=https://www.right.codes
