		"db:pg:seed-patches": "node scripts/seed-postgres-patches.mjs",
		"db:migrate:sqlite-to-pg": "node scripts/migrate-sqlite-to-postgres.mjs",
		"start": "node dist/main.js",
		"smoke:commerce": "node scripts/commerce-smoke.mjs",
		"smoke:project-chapter": "node scripts/project-chapter-smoke.mjs",
		"audit:commerce:catalog": "node scripts/audit-commerce-catalog.mjs",
